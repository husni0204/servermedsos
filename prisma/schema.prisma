// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  // provider = "prisma-client"
  // output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id Int @id @default(autoincrement())
  fullname String @db.VarChar(255)
  email String @unique @db.VarChar(255)
  username String @unique @db.VarChar(255)
  password String @db.VarChar(255)
  bio String? @db.Text
  image String? @db.VarChar(255)
  imageId String? @db.VarChar(255)
  followingCount Int @db.Integer @default(0)
  followerCount Int @db.Integer @default(0)
  postCount Int @db.Integer @default(0)
  createdAt DateTime @default(now())
  posts Post[]
  comments Comment[]
  bookmarks Bookmark[]
  likes Likes[]
  followings Follow[] @relation("Followings")
  followers Follow[] @relation("Followers")
}

model Post {
  id           Int        @id @default(autoincrement())
  userId       Int
  user User @relation(fields: [userId], references: [id])
  image        String     @db.VarChar(255)
  imageId      String     @db.VarChar(255)
  caption      String    @db.Text
  commentCount Int @db.Integer @default(0)
  likeCount Int @db.Integer @default(0)
  createdAt DateTime @default(now())
  comments Comment[]
  likes Likes[]
  bookmarks Bookmark[]
}

model Comment {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  postId    Int
  post      Post     @relation(fields: [postId], references: [id])
  content   String   @db.Text
  createdAt DateTime @default(now())
}

model Bookmark {
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  postId    Int
  post      Post     @relation(fields: [postId], references: [id])
  createdAt DateTime @default(now())

  @@id([userId, postId])
}

model Likes {
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  postId    Int
  post      Post     @relation(fields: [postId], references: [id])
  createdAt DateTime @default(now())

  @@id([userId, postId])
}

model Follow {
  followerId  Int
  follower    User     @relation("Followers", fields: [followerId], references: [id])
  followingId Int
  following   User     @relation("Followings", fields: [followingId], references: [id])
  createdAt   DateTime @default(now())

  @@id([followerId, followingId])
}